{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "test": "vitest",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "@hono/zod-openapi": "^1.4.0",
    "@my-better-t-app/db": "workspace:*",
    "@my-better-t-app/env": "workspace:*",
    "@scalar/hono-api-reference": "^0.10.18",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.8.2",
    "hono-pino": "^0.10.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "stoker": "^2.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@my-better-t-app/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.8",
    "tsdown": "^0.21.9",
    "typescript": "catalog:",
    "vitest": "^4.1.7"
  }
}
